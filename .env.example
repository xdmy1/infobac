# =============================================================================
# InfoBac.md — Environment variables
# Copy this file to .env.local and fill in real values for local development.
# In production (Vercel), set these in the Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Public-facing canonical URL. Used for metadata, OG images, sitemap, emails.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Preview mode (development only)
# -----------------------------------------------------------------------------
# Set to "1" to see the authenticated UI (/dashboard, /curs/...) without
# configuring Supabase. The (app) layout serves mock data and shows a banner.
# Auto-disabled when Supabase is configured — you never serve mock data
# accidentally to a logged-in user.
NEXT_PUBLIC_PREVIEW_MODE=1

# -----------------------------------------------------------------------------
# Supabase — Auth + Database + Storage
# Create a project at https://supabase.com/dashboard, then copy from:
# Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser. Used for admin tasks
# (creating webhooks, running migrations, server-side mutations that bypass RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# -----------------------------------------------------------------------------
# Resend — Transactional email
# Sign up at https://resend.com, then create an API key.
# Verify the sending domain (infobac.md) under Resend → Domains before going live.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=hello@infobac.md
RESEND_FROM_NAME=InfoBac

# -----------------------------------------------------------------------------
# Optional: Analytics / Error tracking (uncomment when ready)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# SENTRY_DSN=
